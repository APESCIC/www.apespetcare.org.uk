DirectoryIndex index.html index.php

RewriteEngine On
ErrorDocument 403 /403.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

RewriteRule ^(?:includes|crawl)(?:/|$) - [F,L,NC]

RewriteRule ^index\.php$ / [R=301,L,NC]
RewriteRule ^(.+/)?index\.php$ /$1 [R=301,L,NC]
RewriteRule ^403\.php$ /403.html [R=301,L,NC]
RewriteRule ^404\.php$ /404.html [R=301,L,NC]
RewriteRule ^500\.php$ /500.html [R=301,L,NC]

RewriteRule ^news/?$ https://www.apesnews.org.uk [R=301,L]
RewriteRule ^news/newsletters/?$ https://www.apesnews.org.uk [R=301,L]
RewriteRule ^news/tag/news-letters/?$ https://www.apesnews.org.uk [R=301,L]
RewriteRule ^Care%20Plans/care-plans/?$ /care-plans/ [R=301,L,NE]
RewriteRule ^APES%20Lab%20Services/apes-lab-services/?$ /lab-services/ [R=301,L,NE]
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L]
